# Navidrome (Subsonic API)
NAVIDROME_URL=http://navidrome.tail.ts.net:4533
NAVIDROME_USER=parm
NAVIDROME_PASS=changeme

# If the controller can read your music files directly from disk,
# set this to the mount path. Much more efficient than streaming over HTTP.
# MUSIC_LIBRARY_PATH=/music

# Ollama on the X1 Pro
OLLAMA_URL=http://x1pro.tail.ts.net:11434
OLLAMA_MODEL=qwen2.5:7b

# Piper TTS — paths inside the container
PIPER_BIN=/usr/local/bin/piper
PIPER_VOICE=/opt/piper/voices/en_GB-alan-medium.onnx
PIPER_VOICE_CONFIG=/opt/piper/voices/en_GB-alan-medium.onnx.json

# Icecast — must match docker-compose
ICECAST_SOURCE_PASSWORD=changeme

# Server
PORT=4000
