{
  "id": "press",
  "name": "Press",
  "description": "Stark broadsheet — bright white stock, near-black ink, black rules, a red headline accent and an ink-blue second.",
  "mode": "light",
  "tokens": {
    "--bg": "#f7f6f2",
    "--surface": "#ffffff",
    "--surface-border": "rgba(17, 17, 17, 0.18)",
    "--field": "#eceae4",
    "--ink": "#111111",
    "--muted": "#4a4a46",
    "--ink-faint": "#8a8a86",
    "--accent": "oklch(0.55 0.23 27)",
    "--accent-2": "oklch(0.42 0.14 250)",
    "--accent-soft": "color-mix(in oklab, oklch(0.55 0.23 27) 10%, #f7f6f2)",
    "--line": "#111111",
    "--soft-border": "rgba(17, 17, 17, 0.14)",
    "--overlay": "rgba(0, 0, 0, 0.06)",
    "--display-font": "instrument-serif",
    "--grain": "0"
  }
}
